# Operator configuration for ds-bashar and host helper scripts.
#
# Copy to /etc/dune/dunectl.env on each VM. Pure KEY=VALUE: sourceable by
# POSIX shell and parseable by Go without a third-party library.
#
# This file is host state. Do not commit a populated copy to the repository.

# Target environment. Required; no default.
# Values: prod | test
TARGET=test

# BattleGroup identifier for `ds-bashar setup`. Becomes the CR `title:`
# field via Funcom's setup.sh. Must be YAML-safe: alphanumeric plus
# underscore/hyphen, no spaces or colons (Funcom's setup.sh writes the
# value as a bare YAML scalar, and ":" / spaces break CR parsing).
# Example: MYBG (this becomes the technical world identifier; the
# in-game server-browser name is set separately via
# `ds-bashar ini-set Bgd.ServerDisplayName "Some Friendly Name"`).
#WORLD_NAME=MYBG

# Region for `ds-bashar setup`. Funcom recognises exactly these five:
# Asia | Europe | North America | Oceania | South America
#WORLD_REGION=Europe

# Optional short identifier patched into the HOST_DATACENTER_ID env-var
# on the Director / Server-Gateway / Text-Router pods. Empty (the
# default) leaves the Funcom vendor default "dune-testing" in place.
# Useful when you want diagnostics to show "<hostname> → <public-ip>"
# instead of the meaningless "dune-testing → <public-ip>".
#HOST_DATACENTER_ID=vm-host-02

# ─── `ds-bashar reconcile` knobs ───────────────────────────────────────
# All optional. `ds-bashar reconcile` is the declarative alternative to
# post-bootstrap.sh; setting any of these here makes the reconcile step
# pick them up.

# Maps to make always-on (space-separated). ds-bashar reconcile runs `enable-set`
# for each, sequentially, to avoid the S2S startup race.
#ALWAYS_ON_SETS="SH_Arrakeen SH_HarkoVillage DeepDesert_1"

# Bgd.ServerDisplayName (in-game server-browser name). Free text.
#SERVER_DISPLAY_NAME="My Server Name"

# Path to a file containing the server-browser password (root:root, 0600).
# When set, ds-bashar reconcile runs `ini-set --apply --restart` for it.
#SERVER_PASSWORD_FILE=/etc/dune/server-password

# Per-pod UDP base ports. Set both to a value >0 to make ds-bashar reconcile run
# `patch-game-ports`; leave at 0 to keep Funcom default 7777/7888.
# Required when two BattleGroups share one public IP behind a vCD edge.
#GAME_PORT_BASE=7877
#IGW_PORT_BASE=7988

# Skip the init-db step (e.g. on a BG that's already past first boot).
#SKIP_INIT_DB=true

# Path to the FLS Self-Host JWT for this target.
# Default if unset: /etc/dune/fls-token-${TARGET}
#FLS_TOKEN_FILE=/etc/dune/fls-token-test

# Optional: additional TLS SANs added to the K3s drop-in, beyond
# the values auto-detected from `hostname -f` and `hostname -A`.
# Use this for FQDNs that are not visible in the VM's local hostname
# database, e.g. external load-balancer names or VPN-internal aliases.
# Space-separated list.
#K3S_EXTRA_TLS_SAN="vm-prod.example.org vm-test.example.org"

# The public IPv4 by which external clients reach this VM. K3s exposes it
# as the node's ExternalIP; Funcom's game-server run.sh queries the K8s
# API for that value at pod startup and uses it as -ExternalAddress on
# the DuneSandbox process. Without it, clients hang at
# "connecting forever" because the server advertises its LAN IP.
# If unset, etc/k3s/install.sh auto-detects via https://api.ipify.org
# at install time.
#K3S_NODE_EXTERNAL_IP=192.0.2.152

# The internal (LAN) IPv4 of this VM. Used by etc/k3s/install.sh to decide
# whether to write the 30-internal-routing.yaml drop-in (mandatory when
# the VM sits behind any DNAT, i.e. K3S_NODE_EXTERNAL_IP differs from the
# internal IP). The drop-in pins K3s' embedded control-plane loopback to
# the internal IP so it does not transit the edge and hit a foreign CA.
# If unset, install.sh auto-detects via `ip route get` (source IP of the
# default route). Set explicitly only on multi-homed VMs where auto-detect
# picks the wrong interface. See docs/shared-public-ip.md.
#K3S_NODE_INTERNAL_IP=192.168.33.66
